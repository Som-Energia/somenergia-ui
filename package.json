  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/index.es.js",
  "exports": {
    ".": {
      "import": "./dist/index.es.js"
    }
  },
  "scripts": {
    "dev": "npm run lint:todos; vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "lint:todos": "todos ./lib",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "preview": "vite preview",
    "deploy-storybook": "npm run build-storybook && touch storybook-static/.nojekyll && gh-pages -d storybook-static --dotfiles",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "npm run build"
  },
