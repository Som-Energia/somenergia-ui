{
  "name": "@somenergia/somenergia-ui",
  "private": false,
  "version": "1.1.2",
  "description": "Common React components for Som Energia projects",
  "license": "AGPL-3.0",
  "homepage": "https://som-energia.github.io/somenergia-ui/",
  "repository": {
